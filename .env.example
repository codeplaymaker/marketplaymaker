# ──────────────────────────────────────────────────────────────────────────────
# MarketPlayMaker Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Bot Connection ───────────────────────────────────────────────────────────

# URL for the bot server (WebSocket + REST)
REACT_APP_BOT_URL=http://localhost:4000
REACT_APP_BOT_API=http://localhost:4000/api

# ─── Firebase Auth (optional — needed for user login) ────────────────────────
# Create a Firebase project at https://console.firebase.google.com

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# ─── Stripe (optional — needed for subscription billing) ─────────────────────
# Get keys at https://dashboard.stripe.com/apikeys

REACT_APP_STRIPE_PUBLISHABLE_KEY=
REACT_APP_STRIPE_BUY_BUTTON_ID=

# ─── Site ─────────────────────────────────────────────────────────────────────

REACT_APP_SITE_URL=http://localhost:3000
