# ──────────────────────────────────────────────────────────────────────────────
# MarketPlayMaker Bot — Environment Variables
# Copy this file to .env and fill in your keys.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────────────────────────────

# OpenAI API key — powers GPT-4o LLM analysis for edge detection
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Recommended ──────────────────────────────────────────────────────────────

# The Odds API — bookmaker consensus for sports/politics edges
# Free tier: 500 requests/month at https://the-odds-api.com
ODDS_API_KEY=

# YouTube Data API v3 — tracks prediction-market YouTube channels
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# NewsData.io — headline sentiment analysis
# Free tier: 200 requests/day at https://newsdata.io
NEWSDATA_API_KEY=

# RapidAPI — Twitter/X syndication fallback
# Get one at https://rapidapi.com
RAPIDAPI_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────

# Bot server port (default: 4000)
BOT_PORT=4000

# Node environment
NODE_ENV=production

# LLM provider and model (default: openai / gpt-4o)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Discord webhook for edge alerts
DISCORD_WEBHOOK_URL=

# Frontend URL for CORS (default: http://localhost:3000)
# Example: https://marketplaymaker.vercel.app
FRONTEND_URL=http://localhost:3000

# Disable authentication for local development (default: false)
AUTH_DISABLED=true

# API key for authenticated routes (when AUTH_DISABLED=false)
API_KEY=

# ─── Stripe (subscription management) ─────────────────────────────────────────

# Stripe secret key — powers webhook signature verification & customer lookup
# Get one at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret — verifies incoming webhook payloads
# Get one at https://dashboard.stripe.com/webhooks (after creating endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# Firebase service account JSON — server-side Firestore access
# Download from Firebase Console → Project Settings → Service Accounts → Generate New Key
# Paste the ENTIRE JSON contents here (or set GOOGLE_APPLICATION_CREDENTIALS to the file path)
FIREBASE_SERVICE_ACCOUNT=

# ─── Execution (NOT required for paper trading) ──────────────────────────────

# Polygon (Polymarket) private key for live order execution
# WARNING: Only set this if you want to execute real trades
# POLYGON_PRIVATE_KEY=

# Polymarket CLOB API credentials (for authenticated CLOB access)
# Get these at https://polymarket.com → Profile → API Keys
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ─── Telegram Bot ─────────────────────────────────────────────────────────────

# Telegram bot token for trade alerts and bot control
# Create a bot via @BotFather on Telegram, then paste the token here
TELEGRAM_BOT_TOKEN=
